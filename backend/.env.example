# Environment Variables Example
# Copy this file to .env and set the values for local development
# For production, set these as environment variables in your deployment platform

# Server Configuration
SERVER_PORT=8090

# Database Configuration
DATABASE_URL=jdbc:postgresql://localhost:5432/futsal_booking
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# JPA Configuration
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false

# Logging Levels
LOG_LEVEL_WEB=info
LOG_LEVEL_SQL=warn
LOG_LEVEL_APP=info

# JWT Configuration
# Generate a strong secret key for production (minimum 256 bits / 32 characters)
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long
JWT_EXPIRATION=86400000

# CORS Configuration
# For production, specify the exact origins allowed (e.g., https://yourdomain.com)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=*
CORS_EXPOSED_HEADERS=Authorization

# File Upload Configuration
MAX_FILE_SIZE=10MB
MAX_REQUEST_SIZE=10MB
FILE_UPLOAD_DIR=uploads
FILE_ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp
